import random

def initialize_weights(num_features):
    # Initialize weights with randomly in [0,1]
    weights = [random.uniform(0, 1) for _ in range(num_features)]
    return weights

def initialize_bias():
    # Initialize bias with a randomly in [0,1]
    bias = random.uniform(0, 1)
    return bias

# how to
num_features = 10  # Number of features in the data

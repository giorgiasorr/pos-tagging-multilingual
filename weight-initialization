import random

def initialize_weights(num_features):
  
    # Initialize weights randomly between in the ranges -1 and 1
    weights = [random.uniform(-1, 1) for _ in range(num_features)]
    return weights

def initialize_bias():
    
    # Initialize bias randomly between -1 and 1
    bias = random.uniform(-1, 1)
    return bias

# Example
num_features = 10  # Replace with the actual number of features
weights = initialize_weights(num_features)
bias = initialize_bias()
